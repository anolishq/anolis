{
  "schema_version": 1,
  "meta": {
    "name": "bioreactor-manual",
    "created": "2026-04-03T00:00:00Z",
    "template": "bioreactor-manual"
  },
  "topology": {
    "runtime": {
      "name": "bioreactor-manual",
      "http_port": 8080,
      "http_bind": "127.0.0.1",
      "cors_origins": ["http://localhost:3000", "http://127.0.0.1:3000"],
      "shutdown_timeout_ms": 3000,
      "startup_timeout_ms": 30000,
      "polling_interval_ms": 2500,
      "log_level": "info",
      "telemetry_enabled": false,
      "automation_enabled": false,
      "behavior_tree_path": null,
      "providers": [
        {
          "id": "bread0",
          "kind": "bread",
          "timeout_ms": 5000,
          "hello_timeout_ms": 2000,
          "ready_timeout_ms": 10000,
          "restart_policy": {
            "enabled": true,
            "max_attempts": 3,
            "backoff_ms": [200, 500, 1000],
            "timeout_ms": 30000,
            "success_reset_ms": 1000
          }
        },
        {
          "id": "ezo0",
          "kind": "ezo",
          "timeout_ms": 5000,
          "hello_timeout_ms": 5000,
          "ready_timeout_ms": 10000,
          "restart_policy": {
            "enabled": true,
            "max_attempts": 3,
            "backoff_ms": [200, 500, 1000],
            "timeout_ms": 30000,
            "success_reset_ms": 1000
          }
        }
      ]
    },
    "providers": {
      "bread0": {
        "kind": "bread",
        "provider_name": "bread0",
        "require_live_session": true,
        "query_delay_us": 10000,
        "timeout_ms": 100,
        "retry_count": 2,
        "devices": [
          { "id": "rlht0", "type": "rlht", "label": "Reactor Temperature Node",   "address": "0x0A" },
          { "id": "dcmt0", "type": "dcmt", "label": "Reactor Media Feed Pumps",   "address": "0x14" },
          { "id": "dcmt1", "type": "dcmt", "label": "Reactor Acid-Base Pumps",    "address": "0x15" }
        ]
      },
      "ezo0": {
        "kind": "ezo",
        "provider_name": "ezo0",
        "query_delay_us": 300000,
        "timeout_ms": 300,
        "retry_count": 2,
        "devices": [
          { "id": "ph0", "type": "ph", "label": "Reactor pH",               "address": "0x63" },
          { "id": "do0", "type": "do", "label": "Reactor Dissolved Oxygen", "address": "0x61" }
        ]
      }
    }
  },
  "paths": {
    "runtime_executable": "build/dev-release/core/anolis-runtime",
    "providers": {
      "bread0": {
        "executable": "../anolis-provider-bread/build/dev-linux-hardware-release/anolis-provider-bread",
        "bus_path": "/dev/i2c-1"
      },
      "ezo0": {
        "executable": "../anolis-provider-ezo/build/dev-linux-hardware-release/anolis-provider-ezo",
        "bus_path": "/dev/i2c-1"
      }
    }
  }
}
